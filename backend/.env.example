# ─── Base de datos PostgreSQL ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gestdist
DB_NAME_PRUEBA=gestdist
DB_NAME_REAL=gestdist_real
DB_USER=postgres
DB_PASSWORD=CAMBIAR_CONTRASENA_AQUI

# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development   # 'production' bloquea /api/reset

# ─── Autenticación JWT ───────────────────────────────────────────────────────
# REQUERIDO: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_POR_SECRETO_ALEATORIO_DE_64_BYTES

# REQUERIDO: Credenciales del único usuario admin
ADMIN_USER=admin
# Opción A — contraseña en texto plano (solo desarrollo):
ADMIN_PASS=CAMBIAR_CONTRASENA_ADMIN
# Opción B — hash SHA-256 (recomendado para producción):
# node -e "console.log(require('crypto').createHash('sha256').update('mipass').digest('hex'))"
# ADMIN_PASS_HASH=abc123...

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
